        <mxCell id="arrow" value="&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#6c5ce7&quot;&gt;&lt;b&gt;DEFENSA&lt;br&gt;EN&lt;br&gt;PROFUNDIDAD&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=4;strokeColor=#6c5ce7;curved=1;endArrow=block;endFill=1;fontColor=#6c5ce7;fontSize=13;fontStyle=1;" edge="1" parent="1" source="arrow-guide-top" target="arrow-guide-bottom">
          <mxGeometry relative="1" as="geometry" />
