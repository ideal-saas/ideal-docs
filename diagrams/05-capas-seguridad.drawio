<mxfile host="app.diagrams.net" modified="2026-06-20T00:00:00.000Z" agent="drawio" version="21.0.0">
  <diagram name="Defensa en Profundidad" id="defense-in-depth">
    <mxGraphModel dx="2200" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2860" pageHeight="2340" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;b&gt;Modelo de Defensa en Profundidad — 8 Capas de Seguridad&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;IDEAL SOFTWARE S.A.S&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#2d3436;" vertex="1" parent="1">
          <mxGeometry x="110" y="15" width="2000" height="50" as="geometry" />
        </mxCell>

        <!-- Layer 1: Internet y DNS -->
        <mxCell id="l1-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 1&lt;/b&gt;&lt;br&gt;Internet y DNS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#dee2e6;fontColor=#212529;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="80" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l1-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• DNS:&lt;/b&gt; idealsoluciones.com.co&lt;br&gt;&lt;b&gt;• Registros A&lt;/b&gt; → IP estática de Lightsail&lt;br&gt;&lt;b&gt;• Subdominios&lt;/b&gt; apuntan a Caddy reverse proxy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="80" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 2: Firewall AWS Lightsail -->
        <mxCell id="l2-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 2&lt;/b&gt;&lt;br&gt;Firewall AWS Lightsail&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ff6b6b;strokeColor=#ee5a24;fontColor=#ffffff;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="210" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l2-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• Solo puertos 80, 443 (HTTPS)&lt;/b&gt; habilitados hacia Internet&lt;br&gt;&lt;b&gt;• Puerto 22 (SSH)&lt;/b&gt; restringido por IP de administradores&lt;br&gt;&lt;b&gt;• Demás puertos BLOQUEADOS&lt;/b&gt; — denegación por defecto&lt;br&gt;&lt;b&gt;• IPv4 firewall&lt;/b&gt; administrado desde consola Lightsail&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="210" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 3: TLS y Cifrado en Tránsito -->
        <mxCell id="l3-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 3&lt;/b&gt;&lt;br&gt;TLS y Cifrado en Tránsito&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#feca57;strokeColor=#f1a428;fontColor=#212529;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="340" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l3-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• TLS 1.2 / 1.3&lt;/b&gt; automático vía Let's Encrypt (Caddy)&lt;br&gt;&lt;b&gt;• HTTP/3 (QUIC)&lt;/b&gt; habilitado para mejor rendimiento y seguridad&lt;br&gt;&lt;b&gt;• Compresión GZIP&lt;/b&gt; en todas las respuestas HTTP&lt;br&gt;&lt;b&gt;• Renovación automática&lt;/b&gt; de certificados sin intervención manual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="340" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 4: Autenticación y Autorización -->
        <mxCell id="l4-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 4&lt;/b&gt;&lt;br&gt;Autenticación y Autorización&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#48dbfb;strokeColor=#0abde3;fontColor=#212529;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="470" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l4-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• Firebase Auth&lt;/b&gt; para autenticación de usuarios finales&lt;br&gt;&lt;b&gt;• JWT con propagación&lt;/b&gt; entre microservicios (NestJS Guards)&lt;br&gt;&lt;b&gt;• SSH ed25519&lt;/b&gt; para acceso administrativo a servidores&lt;br&gt;&lt;b&gt;• GitHub Environments + Reviewers&lt;/b&gt; para control de despliegues&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="470" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 5: Aislamiento de Red -->
        <mxCell id="l5-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 5&lt;/b&gt;&lt;br&gt;Aislamiento de Red&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a29bfe;strokeColor=#6c5ce7;fontColor=#ffffff;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="600" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l5-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• 7 redes Docker aisladas&lt;/b&gt; (accounting-net, kafka-net, api-dian-net, etc.)&lt;br&gt;&lt;b&gt;• Principio de mínimo privilegio&lt;/b&gt; — solo redes necesarias por servicio&lt;br&gt;&lt;b&gt;• Sin puertos públicos directos&lt;/b&gt; a bases de datos ni microservicios&lt;br&gt;&lt;b&gt;• Caddy como único punto de entrada&lt;/b&gt; a la red interna&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="600" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 6: Seguridad de Aplicación -->
        <mxCell id="l6-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 6&lt;/b&gt;&lt;br&gt;Seguridad de Aplicación&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#55a3f0;strokeColor=#2e86de;fontColor=#ffffff;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="730" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l6-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• Imágenes Docker inmutables&lt;/b&gt; — nada se modifica en runtime&lt;br&gt;&lt;b&gt;• Alpine Linux&lt;/b&gt; como base mínima (superficie de ataque reducida)&lt;br&gt;&lt;b&gt;• Límites de memoria y CPU&lt;/b&gt; por contenedor (evita DoS interno)&lt;br&gt;&lt;b&gt;• .env no versionados&lt;/b&gt; — secretos excluidos de Git (.gitignore)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="730" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 7: Seguridad de Datos -->
        <mxCell id="l7-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 7&lt;/b&gt;&lt;br&gt;Seguridad de Datos&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00d2d3;strokeColor=#01a3a4;fontColor=#ffffff;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="860" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l7-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• Lightsail Managed DB&lt;/b&gt; — bases de datos NO expuestas públicamente&lt;br&gt;&lt;b&gt;• Cifrado en reposo&lt;/b&gt; habilitado en todas las instancias de base de datos&lt;br&gt;&lt;b&gt;• Backups diarios automáticos&lt;/b&gt; con retención de 7 días&lt;br&gt;&lt;b&gt;• Final snapshots&lt;/b&gt; al eliminar instancias (recuperación de desastres)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="860" width="1620" height="120" as="geometry" />
        </mxCell>

        <!-- Layer 8: Monitoreo y Detección -->
        <mxCell id="l8-left" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;CAPA 8&lt;/b&gt;&lt;br&gt;Monitoreo y Detección&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2ed573;strokeColor=#26a65b;fontColor=#ffffff;fontSize=18;fontStyle=1;arcSize=6;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="990" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="l8-right" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;• Grafana Cloud&lt;/b&gt; — dashboards centralizados de infraestructura&lt;br&gt;&lt;b&gt;• cAdvisor&lt;/b&gt; — métricas de uso de contenedores en tiempo real&lt;br&gt;&lt;b&gt;• Logs centralizados&lt;/b&gt; vía Grafana Alloy + Loki&lt;br&gt;&lt;b&gt;• UptimeRobot 24/7&lt;/b&gt; + alertas automáticas por Telegram&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#dee2e6;fontColor=#333333;fontSize=14;arcSize=6;align=left;verticalAlign=top;spacingLeft=20;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="990" width="1620" height="120" as="geometry" />
        </mxCell>

