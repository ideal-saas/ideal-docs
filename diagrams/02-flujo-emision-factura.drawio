        <!-- Step 11: API DIAN self-loop -->
        <mxCell id="s10" value="&lt;font style=&quot;font-size:11px&quot;&gt;⑪ Construye XML UBL 2.1 + firma X.509 + CUFE SHA-384&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1A3A5C;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2120" y="660" as="sourcePoint"/>
