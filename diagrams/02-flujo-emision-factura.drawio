        <mxCell id="split-red" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;RECHAZADO — Errores DIAN&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#DC3545;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
