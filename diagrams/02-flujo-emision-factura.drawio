            <mxPoint x="2120" y="885" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== DIAMOND DECISION ===== -->
        <mxCell id="diamond" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="2095" y="920" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== SPLIT: GREEN (APROBADO) flow ===== -->

        <!-- Green connector from diamond to step 14g -->
        <mxCell id="split-green" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;APROBADO — CUFE asignado&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2120" y="970" as="sourcePoint"/>
            <Array as="points">
              <mxPoint x="2020" y="970"/>
              <mxPoint x="2020" y="1000"/>
              <mxPoint x="2120" y="1000"/>
            </Array>
            <mxPoint x="2120" y="1000" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 14g: API DIAN → MySQL (green) -->
        <mxCell id="s13g" value="&lt;font style=&quot;font-size:11px&quot;&gt;⑭ Actualiza estado APROBADO&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2120" y="1030" as="sourcePoint"/>
            <mxPoint x="2355" y="1030" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 15g: Consumer → PostgreSQL (green) -->
        <mxCell id="s14g" value="&lt;font style=&quot;font-size:11px&quot;&gt;⑮ Actualiza factura con CUFE&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
