        <!-- Step 13: DIAN → API DIAN (return response) -->
        <mxCell id="s12" value="&lt;font style=&quot;font-size:11px&quot;&gt;⑬ Respuesta (APROBADO o RECHAZADO)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1A3A5C;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
