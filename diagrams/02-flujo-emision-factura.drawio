              <mxPoint x="2200" y="690"/>
              <mxPoint x="2120" y="690"/>
            </Array>
            <mxPoint x="2120" y="715" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== STEPS 12-16: ZONE C ===== -->

        <!-- Step 12: API DIAN → DIAN -->
        <mxCell id="s11" value="&lt;font style=&quot;font-size:11px&quot;&gt;⑫ Transmite XML firmado (SOAP/HTTPS)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1A3A5C;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
